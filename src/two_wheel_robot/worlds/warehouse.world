          <material><ambient>0.8 0.8 0.8 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ===== GLASS PARTITION (left side) ===== -->
    <model name="glass_left">
      <static>true</static>
      <pose>-3 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.1 6 1</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.1 6 1</size></box></geometry>
          <material><ambient>0.6 0.8 1 0.4</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ===== WORKSTATION TABLES (left cluster) ===== -->
    <model name="table_1">
      <static>true</static>
      <pose>-1.5 2 0.4 0 0 0</pose>
      <link name="link">
