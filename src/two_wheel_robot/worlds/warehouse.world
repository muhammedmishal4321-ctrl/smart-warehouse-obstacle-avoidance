    <!-- ===== LONG DESK (right side) ===== -->
    <model name="long_desk">
      <static>true</static>
      <pose>4 0 0.4 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.6 6 0.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.6 6 0.8</size></box></geometry>
