      <link name="link">
        <collision name="col"><geometry><box><size>1.2 0.6 0.8</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>1.2 0.6 0.8</size></box></geometry>
          <material><ambient>0.9 0.9 0.8 1</ambient></material>
        </visual>
