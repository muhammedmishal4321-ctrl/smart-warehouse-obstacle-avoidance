<?xml version="1.0"?>

<robot name="two_wheel_robot">

<!-- ================= BASE ================= -->

<link name="base_link">
  <visual>
    <geometry>
      <box size="0.30 0.20 0.08"/>
    </geometry>
    <material name="blue">
      <color rgba="0 0 1 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="0.30 0.20 0.08"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="2.0"/>
    <origin xyz="0 0 0"/>
    <inertia
      ixx="0.1" ixy="0" ixz="0"
      iyy="0.1" iyz="0"
      izz="0.1"/>
  </inertial>

</link>


<!-- ================= LEFT WHEEL ================= -->

<link name="left_wheel">
  <visual>
    <origin xyz="0 0 0" rpy="1.57 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.03"/>
    </geometry>
    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>
  </visual>
<collision>
  <origin xyz="0 0 0" rpy="1.57 0 0"/>
  <geometry>
    <cylinder radius="0.05" length="0.03"/>
  </geometry>
</collision>

 <inertial>
    <mass value="0.2"/>
    <origin xyz="0 0 0"/>
    <inertia
      ixx="0.0001" ixy="0" ixz="0"
      iyy="0.0001" iyz="0"
      izz="0.0001"/>
  </inertial>
</link>

<joint name="left_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="left_wheel"/>
  <origin xyz="0 0.15 -0.04" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
</joint>

<!-- ================= RIGHT WHEEL ================= -->

<!-- RIGHT WHEEL -->

<link name="right_wheel">
  <visual>
    <origin xyz="0 0 0" rpy="1.57 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.03"/>
    </geometry>
    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>
  </visual>

<collision>
    <origin xyz="0 0 0" rpy="1.57 0 0"/>
    <geometry>
      <cylinder radius="0.05" length="0.03"/>
    </geometry>
  </collision>

<inertial>
    <mass value="0.2"/>
    <origin xyz="0 0 0"/>
    <inertia
      ixx="0.0001" ixy="0" ixz="0"
      iyy="0.0001" iyz="0"
      izz="0.0001"/>
  </inertial>

</link>

<joint name="right_wheel_joint" type="continuous">
  <parent link="base_link"/>
  <child link="right_wheel"/>
   <origin xyz="0 -0.15 -0.04" rpy="0 0 0"/>
  <axis xyz="0 1 0"/>
</joint>

<!-- ================= CASTER WHEEL ================= -->

<link name="caster_wheel">

  <visual>
    <geometry>
      <sphere radius="0.03"/>
    </geometry>
    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>
  </visual>

 <collision>
    <geometry>
      <sphere radius="0.05"/>
    </geometry>
  </collision>
<inertial>
    <mass value="0.1"/>
    <origin xyz="0 0 0"/>
    <inertia
      ixx="0.0001" ixy="0" ixz="0"
      iyy="0.0001" iyz="0"
      izz="0.0001"/>
  </inertial>

</link>

<joint name="caster_joint" type="continuous">
  <parent link="base_link"/>
  <child link="caster_wheel"/>
  <origin xyz="0.12 0 -0.04"/>
</joint>

<!-- ================= LIDAR ================= -->

<link name="lidar_link">

  <visual>
    <geometry>
      <cylinder radius="0.03" length="0.02"/>
    </geometry>
    <material name="grey">
      <color rgba="0.5 0.5 0.5 1"/>
    </material>
  </visual>

</link>

<joint name="lidar_joint" type="fixed">
  <parent link="base_link"/>
  <child link="lidar_link"/>
  <origin xyz="0 0 0.06"/>
</joint>

<gazebo reference="lidar_link">
  <sensor type="ray" name="lidar_sensor">
    
    <pose>0 0 0 0 0 0</pose>
    <visualize>true</visualize>
    <update_rate>10</update_rate>

    <ray>
      <scan>
        <horizontal>
          <samples>720</samples>
          <resolution>1</resolution>
          <min_angle>-3.14</min_angle>
          <max_angle>3.14</max_angle>
        </horizontal>
      </scan>

      <range>
        <min>0.12</min>
        <max>8.0</max>
        <resolution>0.01</resolution>
      </range>
    </ray>

    <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
      <ros>
        <remapping>~/out:=/scan</remapping>
      </ros>
      <output_type>sensor_msgs/LaserScan</output_type>
      <frame_name>lidar_link</frame_name>
    </plugin>

  </sensor>
</gazebo>


<!-- ================= CAMERA ================= -->

<link name="camera_link">

  <visual>
    <geometry>
      <box size="0.03 0.03 0.03"/>
    </geometry>
    <material name="black">
      <color rgba="0 0 0 1"/>
    </material>
  </visual>

</link>

<joint name="camera_joint" type="fixed">
  <parent link="base_link"/>
  <child link="camera_link"/>
  <origin xyz="0.10 0 0.06"/>
</joint>


<!-- ================= DIFF DRIVE PLUGIN ================= -->

<gazebo>

  <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">

    <left_joint>left_wheel_joint</left_joint>
 Movement using /cmd_vel    <right_joint>right_wheel_joint</right_joint>

    <wheel_separation>0.30</wheel_separation>
    <wheel_diameter>0.10</wheel_diameter>

    <robot_base_frame>base_link</robot_base_frame>

    <command_topic>cmd_vel</command_topic>
    <odometry_topic>odom</odometry_topic>

    <publish_odom>true</publish_odom>

  </plugin>

</gazebo>

<gazebo reference="left_wheel">
  <mu1>1.0</mu1>
  <mu2>1.0</mu2>
</gazebo>

<gazebo reference="right_wheel">
  <mu1>1.0</mu1>
  <mu2>1.0</mu2>
</gazebo>

<gazebo reference="caster_wheel">
  <mu1>0.1</mu1>
  <mu2>0.1</mu2>
</gazebo>
</robot>
